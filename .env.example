# --- Desarrollo local (usar estas variables) ---
DB_HOST=localhost
DATABASE=postgres
DB_USER=admin
DB_PORT=5432
DB_PASSWORD=password

# --- Producción con Supabase ---
# Usar el formato postgresql+asyncpg:// (no postgres:// ni postgresql://)
# No incluir ?sslmode=require (el código ya configura SSL via connect_args)
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
